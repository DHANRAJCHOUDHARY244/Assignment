{
  "name": "backend",
  "version": "1.0.0",
  "description": "Backend for the application",
  "main": "dist/server.js",
  "scripts": {
    "dev": "dotenvx run -f .env.dev -- tsx watch src/server.ts",
    "start": "dotenvx run -f .env.prod -- node dist/server.js",
    "test": "dotenvx run -f .env.dev -- jest --coverage --passWithNoTests",
    "test:watch": "dotenvx run -f .env.dev -- jest --watch --passWithNoTests",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "build": "tsc -p tsconfig.build.json && tsc-esm-fix",
    "check": "npm run lint && npm run test && npm run build",
    "format": "prettier . --write",
    "prepare": "husky",
    "seed": "dotenvx run -f .env.dev -- tsx src/scripts/seed.ts",
    "seed:force": "dotenvx run -f .env.dev -- tsx src/scripts/seed.ts --force"
  },
  "keywords": [],
  "author": "choudharydhanraj2392gmail.com",
  "license": "ISC",
  "type": "module",
  "packageManager": "pnpm@10.28.0",
  "dependencies": {
    "@dotenvx/dotenvx": "^1.52.0",
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dayjs": "^1.11.19",
    "envalid": "^8.1.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "handlebars": "^4.7.8",
    "helmet": "^8.1.0",
    "joi": "^18.0.2",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.7.4",
    "morgan": "^1.10.1",
    "multer": "^2.2.0",
    "nodemailer": "^8.0.1",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.37.0",
    "@types/bcryptjs": "^3.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.2.0",
    "@types/node": "^25.2.2",
    "@types/nodemailer": "^7.0.9",
    "eslint": "^9.37.0",
    "globals": "^17.3.0",
    "husky": "^9.1.7",
    "jest": "^30.2.0",
    "jiti": "^2.6.1",
    "lint-staged": "^16.2.7",
    "prettier": "3.8.1",
    "ts-jest": "^29.4.6",
    "tsc-esm-fix": "^3.1.2",
    "tslib": "^2.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.0"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=22.20.0"
  }
}
